# Database Configuration
DATABASE_URL=your_database_url_here
PGHOST=your_pg_host
PGPORT=5432
PGUSER=your_pg_user
PGPASSWORD=your_pg_password
PGDATABASE=your_pg_database

# Session Secret
SESSION_SECRET=your_session_secret_here

# PayFast Configuration (South African Payment Gateway)
# Get your credentials from https://www.payfast.co.za
PAYFAST_MERCHANT_ID=your_payfast_merchant_id
PAYFAST_MERCHANT_KEY=your_payfast_merchant_key
PAYFAST_PASSPHRASE=your_payfast_passphrase
PAYFAST_SANDBOX=true

# Zapper Configuration (South African Mobile Payments)
# Get your credentials from https://www.zapper.com
ZAPPER_MERCHANT_ID=your_zapper_merchant_id
ZAPPER_SITE_ID=your_zapper_site_id
ZAPPER_API_KEY=your_zapper_api_key
ZAPPER_SANDBOX=true

# Apple Pay Configuration
# Register at https://developer.apple.com
APPLE_PAY_MERCHANT_ID=your_apple_pay_merchant_id

# Stripe Configuration (Optional - currently using PayFast/Zapper for ZAR)
STRIPE_SECRET_KEY=your_stripe_secret_key
VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key
TESTING_STRIPE_SECRET_KEY=your_testing_stripe_secret_key
TESTING_VITE_STRIPE_PUBLIC_KEY=your_testing_stripe_public_key
